{
  "name": "notify",
  "version": "0.0.1",
  "description": "web 2.0 style notification systems for discord, email, and sms",
  "keywords": [
    "discord",
    "email",
    "notification",
    "sms"
  ],
  "license": "MIT",
  "author": "wajeht",
  "main": "index.js",
  "scripts": {
    "start": "export APP_ENV=production && node --no-warnings ./dist/src/server.js",
    "dev": "export APP_ENV=development && npm run db:prepare:dev && tsx watch --no-warnings --clear-screen=false --exclude './src/views/*/*' ./src/server.ts ",
    "build:server": "tsc",
    "build": "npm run build:server",
    "update:deps": "npx npm-check -u",
    "check:deps": "npx depcheck",
    "test:unit": "echo 'not yet'",
    "test:browser:headless": "npx playwright test",
    "test:browser": "npx playwright test --ui",
    "test:watch": "NODE_ENV=testing  vitest",
    "test": "NODE_ENV=testing vitest --run",
    "test:coverage": "NODE_ENV=testing vitest run --coverage",
    "format:check": "oxfmt --check .",
    "format:verbose": "oxfmt --write .",
    "format": "oxfmt --write . > /dev/null",
    "lint:check": "oxlint .",
    "lint": "oxlint --fix .",
    "db:prepare:dev": "npm run db:migrate:latest && npm run db:seed:run",
    "db:prepare:prod": "npm run db:migrate:latest:prod",
    "db:migrate:make": "tsx ./node_modules/knex/bin/cli.js migrate:make --knexfile=./src/db/knexfile.ts",
    "db:migrate:latest:prod": "knex migrate:latest --knexfile=./dist/src/db/knexfile.js",
    "db:migrate:latest": "tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile=./src/db/knexfile.ts",
    "db:migrate:rollback": "tsx ./node_modules/knex/bin/cli.js migrate:rollback --knexfile=./src/db/knexfile.ts",
    "db:migrate:rollback:prod": "knex migrate:rollback --knexfile=./dist/src/db/knexfile.js",
    "db:seed:make": "tsx ./node_modules/knex/bin/cli.js seed:make --knexfile=./src/db/knexfile.ts",
    "db:seed:run": "tsx ./node_modules/knex/bin/cli.js seed:run --knexfile=./src/db/knexfile.ts",
    "db:seed:run:prod": "knex seed:run --knexfile=./dist/src/db/knexfile.js",
    "rebuild:native": "npm rebuild better-sqlite3 esbuild --ignore-scripts=false"
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "compression": "1.8.1",
    "connect-flash": "0.1.1",
    "connect-session-knex": "5.0.0",
    "cors": "2.8.6",
    "csrf-sync": "4.2.1",
    "dotenv": "17.4.2",
    "eta": "4.6.0",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "express-session": "1.19.0",
    "express-validator": "7.3.2",
    "helmet": "8.2.0",
    "jsonwebtoken": "9.0.3",
    "knex": "3.2.10",
    "nodemailer": "8.0.10",
    "twilio": "6.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "0.5.19",
    "@types/better-sqlite3": "7.6.13",
    "@types/compression": "1.8.1",
    "@types/connect-flash": "0.0.40",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/nodemailer": "8.0.0",
    "@vitest/coverage-v8": "4.1.7",
    "@wajeht/express-templates-reload": "3.0.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "overrides": {
    "axios": "1.16.1",
    "follow-redirects": "1.16.0",
    "path-to-regexp": "8.4.2",
    "qs": "6.15.2"
  },
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.16.0"
}
